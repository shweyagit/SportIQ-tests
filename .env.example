# SportIQ RAG Test Suite — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Required ───────────────────────────────────────────────────────────────────

# Base URL of the SportIQ API (no trailing slash)
SPORTIQ_API_URL=https://sportiq-voxv.onrender.com

# Anthropic API key — used by Claude Haiku as the LLM judge in deepeval and RAGAS
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ───────────────────────────────────────────────────────────────────

# Uncomment to run against a local development server instead
# SPORTIQ_API_URL=http://localhost:3000
